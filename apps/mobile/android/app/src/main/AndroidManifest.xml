<?xml version="1.0" encoding="utf-8"?>
<!--
  Task 4 — Android Health Connect stub manifest.

  Required additions for Health Connect integration:
  1. The <queries> block declares intent visibility so the app can detect
     whether Health Connect is installed on the device.
  2. The <uses-permission> entries declare the data types we intend to read.
     These must match GARMIN_READ_PERMISSIONS in wearablePermissions.ts.

  TODO(hardware-verification): Confirm permission strings against the
  installed Health Connect SDK version on a real device.
  Track in: docs/garmin-datapath-tech-debt.md
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- Health Connect availability check -->
    <queries>
        <package android:name="com.google.android.apps.healthdata" />
    </queries>

    <!-- Health Connect read permissions -->
    <uses-permission android:name="android.permission.health.READ_STEPS" />
    <uses-permission android:name="android.permission.health.READ_HEART_RATE" />
    <uses-permission android:name="android.permission.health.READ_ACTIVE_CALORIES_BURNED" />
    <uses-permission android:name="android.permission.health.READ_DISTANCE" />
    <uses-permission android:name="android.permission.health.READ_SLEEP" />

    <application
        android:name=".MainApplication"
        android:label="@string/app_name"
        android:icon="@mipmap/ic_launcher"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:allowBackup="false"
        android:theme="@style/AppTheme">

        <activity
            android:name=".MainActivity"
            android:label="@string/app_name"
            android:configChanges="keyboard|keyboardHidden|orientation|screenLayout|screenSize|smallestScreenSize|uiMode"
            android:launchMode="singleTask"
            android:windowSoftInputMode="adjustResize"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
    </application>

</manifest>
