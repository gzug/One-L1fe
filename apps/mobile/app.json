{
  "expo": {
    "name": "One L1fe",
    "slug": "one-l1fe-mobile",
    "version": "0.2.1",
    "orientation": "portrait",
    "userInterfaceStyle": "automatic",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "package": "com.onel1fe.mobile",
      "minSdkVersion": 26,
      "versionCode": 3
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "./plugins/with-health-connect",
      "expo-font"
    ]
  }
}
